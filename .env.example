# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
# Optional overrides (defaults: gpt-image-1 / medium). Quality: low | medium | high | auto
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=medium

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret pepper for hashing client IPs (anti-abuse quota); generate with: openssl rand -hex 32
IP_HASH_SECRET=
